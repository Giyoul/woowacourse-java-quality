{
  "name": "woowacourse-quality-checker",
  "version": "1.0.0",
  "description": "MCP plugin that checks Java code against Woowacourse coding standards",
  "main": "dist/index.js",
  "bin": {
    "woowacourse-quality-checker": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "start": "node dist/index.js"
  },
  "keywords": ["mcp", "java", "quality", "woowacourse", "static-analysis"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.ts"],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
